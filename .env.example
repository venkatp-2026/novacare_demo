# NovaCare Health - Environment Variables
# Copy this file to .env and set your values

# API Token for authentication
# This token is used by the frontend to authenticate API requests
# The frontend automatically fetches this from the /api/config endpoint
MOCK_API_TOKEN=dcJuI3Tx+VQq9IfCJ7egXiGcDj2uof8xqNqemktrp5c=

# For local development, you can set this in your terminal:
# PowerShell: $env:MOCK_API_TOKEN="your-token-here"
# Bash: export MOCK_API_TOKEN="your-token-here"

# On Vercel, set this in your project's Environment Variables:
# Dashboard -> Settings -> Environment Variables -> Add
